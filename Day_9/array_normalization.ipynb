      "id": "77f26385-1039-4f7e-82bc-e16274851801",
      "cell_type": "code",
      "source": "arr = np.array([[2,3,5],[7,8,1]])\nprint(arr)\nmean = arr.mean()\nstandard_deviation = arr.std()\nnormalization = (arr - mean)/standard_deviation\nprint(normalization)\nprint(mean)\nprint(standard_deviation)",
      "metadata": {
        "trusted": true
      },
