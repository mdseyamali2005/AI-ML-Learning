   "outputs": [],
   "source": [
    "import numpy as np"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "77f26385-1039-4f7e-82bc-e16274851801",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[[2 3 5]\n",
      " [7 8 1]]\n",
      "[[-0.91132238 -0.52075564  0.26037782]\n",
      " [ 1.04151129  1.43207802 -1.30188911]]\n",
      "4.333333333333333\n",
      "2.5603819159562025\n"
     ]
    }
   ],
   "source": [
    "arr = np.array([[2,3,5],[7,8,1]])\n",
    "print(arr)\n",
    "mean = arr.mean()\n",
    "standard_deviation = arr.std()\n",
    "normalization = (arr - mean)/standard_deviation\n",
    "print(normalization)\n",
    "print(mean)\n",
    "print(standard_deviation)"
   ]
  }
 ],
